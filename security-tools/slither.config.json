{
  "detectors_to_run": [
    "reentrancy-eth",
    "reentrancy-no-eth", 
    "reentrancy-unlimited-gas",
    "arbitrary-send-erc20",
    "arbitrary-send-erc20-permit",
    "unchecked-transfer",
    "unchecked-lowlevel",
    "controlled-array-length",
    "controlled-delegatecall",
    "dao",
    "locked-ether",
    "delegatecall-loop",
    "msg-value-loop",
    "reused-constructor",
    "immutable-states",
    "timestamp",
    "block-number",
    "assembly",
    "encode-packed-collision",
    "variable-scope",
    "void-cmp",
    "suicidal",
    "shadowing-local",
    "shadowing-builtin",
    "shadowing-abstract",
    "uninitialized-local",
    "uninitialized-state",
    "uninitialized-storage",
    "missing-zero-check",
    "calls-loop",
    "costly-loop",
    "divide-before-multiply",
    "incorrect-equality",
    "incorrect-return",
    "weak-prng",
    "assert-state-change"
  ],
  "detectors_to_exclude": [
    "naming-convention",
    "external-function",
    "constable-states",
    "unused-return"
  ],
  "filter_paths": [
    "node_modules",
    "lib",
    "test",
    "testing",
    "contracts-v2/test",
    "@openzeppelin"
  ],
  "compile_force_framework": "hardhat",
  "solc_remaps": [
    "@openzeppelin/=node_modules/@openzeppelin/"
  ],
  "solc_args": "--optimize --optimize-runs 200",
  "include_paths": [
    "contracts-v2"
  ]
}
