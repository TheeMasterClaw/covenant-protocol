{"ast":null,"code":"import{useState,useEffect}from'react';export function useTheme(){const[theme,setTheme]=useState(()=>{const saved=localStorage.getItem('covenant-theme');return saved||'dark';});useEffect(()=>{document.documentElement.setAttribute('data-theme',theme);localStorage.setItem('covenant-theme',theme);},[theme]);const toggleTheme=()=>{setTheme(prev=>prev==='dark'?'light':'dark');};return{theme,toggleTheme,isDark:theme==='dark'};}","map":{"version":3,"names":["useState","useEffect","useTheme","theme","setTheme","saved","localStorage","getItem","document","documentElement","setAttribute","setItem","toggleTheme","prev","isDark"],"sources":["/home/azureuser/covenant/frontend/src/hooks/useTheme.js"],"sourcesContent":["import { useState, useEffect } from 'react';\n\nexport function useTheme() {\n  const [theme, setTheme] = useState(() => {\n    const saved = localStorage.getItem('covenant-theme');\n    return saved || 'dark';\n  });\n\n  useEffect(() => {\n    document.documentElement.setAttribute('data-theme', theme);\n    localStorage.setItem('covenant-theme', theme);\n  }, [theme]);\n\n  const toggleTheme = () => {\n    setTheme(prev => prev === 'dark' ? 'light' : 'dark');\n  };\n\n  return { theme, toggleTheme, isDark: theme === 'dark' };\n}\n"],"mappings":"AAAA,OAASA,QAAQ,CAAEC,SAAS,KAAQ,OAAO,CAE3C,MAAO,SAAS,CAAAC,QAAQA,CAAA,CAAG,CACzB,KAAM,CAACC,KAAK,CAAEC,QAAQ,CAAC,CAAGJ,QAAQ,CAAC,IAAM,CACvC,KAAM,CAAAK,KAAK,CAAGC,YAAY,CAACC,OAAO,CAAC,gBAAgB,CAAC,CACpD,MAAO,CAAAF,KAAK,EAAI,MAAM,CACxB,CAAC,CAAC,CAEFJ,SAAS,CAAC,IAAM,CACdO,QAAQ,CAACC,eAAe,CAACC,YAAY,CAAC,YAAY,CAAEP,KAAK,CAAC,CAC1DG,YAAY,CAACK,OAAO,CAAC,gBAAgB,CAAER,KAAK,CAAC,CAC/C,CAAC,CAAE,CAACA,KAAK,CAAC,CAAC,CAEX,KAAM,CAAAS,WAAW,CAAGA,CAAA,GAAM,CACxBR,QAAQ,CAACS,IAAI,EAAIA,IAAI,GAAK,MAAM,CAAG,OAAO,CAAG,MAAM,CAAC,CACtD,CAAC,CAED,MAAO,CAAEV,KAAK,CAAES,WAAW,CAAEE,MAAM,CAAEX,KAAK,GAAK,MAAO,CAAC,CACzD","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}