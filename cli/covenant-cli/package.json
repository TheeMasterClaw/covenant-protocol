{
  "name": "@covenantprotocol/cli",
  "version": "1.0.0",
  "description": "Official CLI tool for COVENANT Protocol - interact with 33+ smart contracts",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "covenant": "dist/index.js",
    "covenant-cli": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src/**/*.ts",
    "prepare": "npm run build",
    "test": "jest",
    "watch": "tsc --watch"
  },
  "keywords": [
    "covenant",
