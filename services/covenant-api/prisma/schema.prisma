generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Covenant {
  id                String    @id @default(uuid())
  address           String    @unique
  creatorAddress    String
  name              String
  description       String?
  termsHash         String
  metadataUri       String?
  chainId           Int
  status            CovenantStatus @default(PENDING)
  version           Int       @default(1)
  implementation    String
  totalValueLocked  Decimal   @default(0) @db.Decimal(78, 0)
  transactionCount  Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  dissolvedAt       DateTime?
  dissolvedReason   String?

  participants      CovenantParticipant[]
  tasks             Task[]
  events            CovenantEvent[]

  @@index([status])
  @@index([chainId])
  @@index([creatorAddress])
  @@map("covenants")
}

model User {
  id                String    @id @default(uuid())
  address           String    @unique
  ensName           String?
  createdAt         DateTime  @default(now())
  totalCovenants    Int       @default(0)
  totalTasks        Int       @default(0)

  covenantRoles     CovenantParticipant[]
  tasksCreated      Task[]    @relation("TaskCreator")
  tasksAssigned     Task[]    @relation("TaskAssignee")
  reputation        ReputationScore?

  @@index([address])
  @@map("users")
}

model CovenantParticipant {
  id          String            @id @default(uuid())
  covenantId  String
  userId      String
  role        ParticipantRole   @default(MEMBER)
  joinedAt    DateTime          @default(now())
  stakeAmount Decimal           @default(0) @db.Decimal(78, 0)
  active      Boolean           @default(true)

  covenant    Covenant          @relation(fields: [covenantId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([covenantId, userId])
  @@index([covenantId])
  @@index([userId])
  @@map("covenant_participants")
}

model Task {
  id              String      @id @default(uuid())
  onChainTaskId   String      @unique
  covenantId      String
  creatorId       String
  assigneeId      String?
  title           String
  description     String?
  reward          Decimal     @db.Decimal(78, 0)
  tokenAddress    String?
  deadline        DateTime
  status          TaskStatus  @default(OPEN)
  category        String?
  priority        Int         @default(1)
  escrowAddress   String?
  escrowAmount    Decimal     @default(0) @db.Decimal(78, 0)
  disputeId       String?
  metadataUri     String?
  chainId         Int
  createdAt       DateTime    @default(now())
  assignedAt      DateTime?
  submittedAt     DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?

  covenant        Covenant    @relation(fields: [covenantId], references: [id], onDelete: Cascade)
  creator         User        @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  assignee        User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reviews         TaskReview[]
  submissions     TaskSubmission[]

  @@index([status])
  @@index([covenantId])
  @@index([assigneeId])
  @@map("tasks")
}

model TaskReview {
  id        String   @id @default(uuid())
  taskId    String
  reviewer  String
  reviewee  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_reviews")
}

model TaskSubmission {
  id          String   @id @default(uuid())
  taskId      String
  submitter   String
  proofUri    String
  comment     String?
  accepted    Boolean?
  submittedAt DateTime @default(now())

  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_submissions")
}

model ReputationScore {
  id                  String   @id @default(uuid())
  userId              String   @unique
  score               Decimal  @db.Decimal(78, 0)
  tier                String   @default("NOVICE")
  stakedAmount        Decimal  @default(0) @db.Decimal(78, 0)
  lockedAmount        Decimal  @default(0) @db.Decimal(78, 0)
  decayFactor         Decimal  @default(1) @db.Decimal(10, 8)
  boostMultiplier     Decimal  @default(1) @db.Decimal(10, 8)
  consecutiveMonths   Int      @default(0)
  totalTasksCompleted Int      @default(0)
  totalTasksCreated   Int      @default(0)
  totalDisputesWon    Int      @default(0)
  totalDisputesLost   Int      @default(0)
  averageRating       Decimal  @default(0) @db.Decimal(3, 2)
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reputation_scores")
}

model CovenantEvent {
  id              String   @id @default(uuid())
  covenantId      String
  eventType       String
  emitter         String
  data            String?
  blockNumber     BigInt
  blockTimestamp  DateTime
  transactionHash String

  covenant        Covenant @relation(fields: [covenantId], references: [id], onDelete: Cascade)

  @@index([covenantId])
  @@index([eventType])
  @@index([blockNumber])
  @@map("covenant_events")
}

enum CovenantStatus {
  PENDING
  ACTIVE
  PAUSED
  DISSOLVED
}

enum ParticipantRole {
  OWNER
  ADMIN
  MEMBER
  OBSERVER
}

enum TaskStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  COMPLETED
  CANCELLED
  DISPUTED
}
